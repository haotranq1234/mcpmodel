{
  "name": "blockbench-mcp-bridge",
  "version": "0.4.0",
  "description": "Local MCP server and WebSocket bridge for precise AI-driven Blockbench modeling",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "blockbench-mcp": "dist/index.js"
  },
  "scripts": {
